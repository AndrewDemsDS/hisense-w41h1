diff --git a/src/app/clusters/fan-control-server/fan-control-server.cpp b/src/app/clusters/fan-control-server/fan-control-server.cpp
index d1f1dd2b..abd8ae9a 100644
--- a/src/app/clusters/fan-control-server/fan-control-server.cpp
+++ b/src/app/clusters/fan-control-server/fan-control-server.cpp
@@ -377,6 +377,20 @@ void MatterFanControlClusterServerAttributeChangedCallback(const app::ConcreteAt
                                ChipLogError(Zcl, "Failed to write SpeedSetting with error: 0x%02x", to_underlying(status)));
             }
         }
+
+        // W41H1 fix: upstream maps only Off and Auto to the speed attributes, so on a
+        // multi-speed device the Low/Medium/High presets never reach PercentSetting/
+        // SpeedSetting (nor the app driver) -- the preset appears to "do nothing" (High
+        // only worked because HA sends it as percent=100). Map them onto a percentage so
+        // the PercentSetting logic below drives the concrete speed
+        // (33/66/100% -> SpeedSetting 2/4/6 at SpeedMax 6 -> Low/Mid/High on the bus).
+        if (mode == FanModeEnum::kLow || mode == FanModeEnum::kMedium || mode == FanModeEnum::kHigh)
+        {
+            Percent pct = (mode == FanModeEnum::kHigh) ? 100 : (mode == FanModeEnum::kMedium) ? 66 : 33;
+            status      = PercentSetting::Set(attributePath.mEndpointId, pct);
+            VerifyOrReturn(Status::Success == status,
+                           ChipLogError(Zcl, "Failed to write PercentSetting with error: 0x%02x", to_underlying(status)));
+        }
         break;
     }
     case PercentSetting::Id: {
