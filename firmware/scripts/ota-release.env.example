# ota-release.sh environment. Copy to `ota-release.env` (gitignored) and fill in.
# Keep real hostnames/paths OUT of git (private-repo scrub convention).

# --- SDK / build (local machine) ---
SDK_ROOT="$HOME/ameba-dev"
GCC_RELEASE="$SDK_ROOT/ameba-rtos-z2/project/realtek_amebaz2_v0_example/GCC-RELEASE"
EXAMPLE_DIR="$SDK_ROOT/ameba-rtos-z2/component/common/application/matter/examples/room_air_conditioner"
CHIP_CONFIG_H="$SDK_ROOT/connectedhomeip/src/include/platform/CHIPDeviceConfig.h"
OTA_TOOL="$SDK_ROOT/connectedhomeip/src/app/ota_image_tool.py"

# --- device identity (Matter test creds) ---
VID="0xFFF1"
PID="0x8001"
NODE_ID="1"

# --- OTA delivery (the Pi running python-matter-server) ---
PI_HOST="root@your-ha-host.local"
PI_OTA_DIR="/path/to/matter-server/ota"        # matches matter-server --ota-provider-dir
PI_SSH_KEY="$HOME/.ssh/id_ed25519"
MS_WS="ws://your-ha-host.local:5580/ws"

# --- OTA client venv (has aiohttp) ---
OTAENV_PY="/path/to/venv/bin/python"

# --- Remote OTA distribution (issue #79; optional) ---
# If set, `package` writes the manifest otaUrl as a RELEASE-ASSET URL instead of a local file://.
# python-matter-server's OTA provider downloads an http(s):// otaUrl (checksum-verified) then
# re-serves it over BDX, so the big .ota can live in the GitHub release and only the small
# .json need be staged on the Pi. The full URL becomes:
#   $OTA_RELEASE_BASE/amebaz2-v<semver>/rac-v<softwareVersionInt>.ota
# Leave UNSET to keep the current fully-local flow (otaUrl = file:///rac-v<int>.ota).
# OTA_RELEASE_BASE="https://github.com/your-org/hisense-w41h1/releases/download"

# --- HTTPS-OTA manual backup target (issue #78) ---
# The break-glass HTTP OTA (triggered by writing Identify.IdentifyTime=88 on ep1) fetches the
# image from a plain-HTTP file server on the Pi. This target is a COMPILE-TIME macro in the
# firmware (firmware/src/sdk-edits/matter_drivers.cpp: HISENSE_OTA_HOST/PORT/RESOURCE), not a
# runtime env -- edit those defaults (or pass -D at build) to point at your Pi. Serve the built
# firmware_is.bin (correct FWHS serial) as that resource, e.g. cp .../firmware_is.bin <docroot>/rac-ota.bin.

# --- AmebaZ2 OTA slot-selection serial (CRITICAL) ---
# The bootloader boots the slot with the HIGHER FWHS serial, NOT the Matter
# softwareVersion. ota-release.sh sets serial = SERIAL_BASE + softwareVersion so it
# always increases with the version. Forgetting this = OTA applies but rolls back.
SERIAL_BASE="1100"

# --- build performance (optional; defaults shown) ---
# CCACHE_MAXSIZE=25G       # ccache size (ninja core already parallel; ccache skips unchanged recompiles)
# CCACHE_DIR="$HOME/.ccache"
