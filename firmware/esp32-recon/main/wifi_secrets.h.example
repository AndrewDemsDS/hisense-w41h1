// Baked-in WiFi creds for HEADLESS / OTA flashing (when there's no UART to run
// the `wifi` command). Copy this file to `wifi_secrets.h` (gitignored) and fill
// it in; recon auto-connects with these when NVS has no creds. Delete the copy
// (or `wifi clear` + reflash) to go back to UART provisioning only.
//
//   cp main/wifi_secrets.h.example main/wifi_secrets.h   # then edit
#pragma once
#define RECON_WIFI_SSID "your-ssid"
#define RECON_WIFI_PASS "your-password"
