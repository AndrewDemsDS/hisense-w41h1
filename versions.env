# Pinned upstream commits/branches the patches + overlays target.
# Single source of truth — sourced by firmware/setup.sh; mirrored in NOTICE.md + UPSTREAM.md.
# The Realtek SDKs are proprietary (not redistributable) — we link + pin, never vendor.

# Realtek AmebaZ2 base SDK (RTL8710C RTOS/BSP) — patches/ameba-rtos-z2.patch targets this commit.
AMEBA_Z2_REPO="https://github.com/Ameba-AIoT/ameba-rtos-z2.git"
AMEBA_Z2_PIN="0ee0460bc2cfbb80d0ae2ff3e952d44a30b856ab"

# Realtek AmebaZ2 Matter component (plugs into the z2 component slot). Branch-pinned.
AMEBA_MATTER_REPO="https://github.com/Ameba-AIoT/ameba-rtos-matter.git"
AMEBA_MATTER_BRANCH="release/v1.4.2"

# Matter SDK (Apache-2.0) — patches/connectedhomeip.patch targets this commit.
CHIP_REPO="https://github.com/project-chip/connectedhomeip.git"
CHIP_BRANCH="v1.4.2-branch"
CHIP_PIN="cc74311cffac7d7e5fe1082322a988277af02bfa"

# ESP-IDF + esp-matter (ESP32 replacement build; both open-source). Used by the ESP32 CI build
# (.github/workflows/esp32-release.yaml). IDF is pinned via the espressif/idf container tag.
IDF_PIN="v5.5.4"
# esp-matter has no upstream release matching IDF 5.5.4, so pin the exact commit the build used
# (esp-matter main @ this SHA, paired with IDF v5.5.4). Update when you re-pin against a newer IDF.
ESP_MATTER_PIN="e0a089b67ce50b454d804a0d624885088327e256"

# HA companion (custom integration + native card). Linked as a submodule under integrations/.
HACS_REPO="https://github.com/AndrewDemsDS/hisense-unified-ac.git"
